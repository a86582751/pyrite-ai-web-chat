{
  "name": "chat-tree",
  "version": "1.0.0",
  "description": "Message tree chat app with multi-model support",
  "scripts": {
    "dev": "concurrently \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "cd server && bun dev",
    "client:dev": "cd client && bun dev",
    "build": "cd client && bun run build",
    "start": "cd server && bun start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
